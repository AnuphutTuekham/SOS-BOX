{
	"buildCommand": "npm run build",
	"outputDirectory": "public",
	"version": 2,
	"redirects": [
		{ "source": "/", "destination": "/main.html", "permanent": false },
		{ "source": "/dashboard", "destination": "/Labmonitor-dashboard.html", "permanent": false },
		{ "source": "/dashboard/", "destination": "/Labmonitor-dashboard.html", "permanent": false }
	],
	"rewrites": [
		{
			"source": "/api/:path*",
			"destination": "https://sos-box-worker.anuphut.workers.dev/api/:path*"
		}
	]
}
